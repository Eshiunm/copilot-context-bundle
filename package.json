{
  "name": "copilot-context-bundle",
  "version": "0.3.2",
  "private": true,
  "description": "CLI and source assets for installing Copilot context bundles into target repositories.",
  "type": "commonjs",
  "bin": {
    "copilot-bundle": "./bin/copilot-bundle.js"
  },
  "files": [
    "bin/",
